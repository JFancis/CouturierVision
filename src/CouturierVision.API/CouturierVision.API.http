@CouturierVision_API_HostAddress = http://localhost:5000

### Create a client
POST {{CouturierVision_API_HostAddress}}/api/clients
Content-Type: application/json

{
  "firstName": "Marie",
  "lastName": "Dupont",
  "email": "marie@example.com",
  "phoneNumber": "0601020304",
  "stylePreferences": "Classique"
}

### Get client by ID
GET {{CouturierVision_API_HostAddress}}/api/clients/00000000-0000-0000-0000-000000000000

### Create an order
POST {{CouturierVision_API_HostAddress}}/api/orders
Content-Type: application/json

{
  "clientId": "00000000-0000-0000-0000-000000000000",
  "totalPrice": 500.00,
  "measurementsJson": "{\"chest\": 100, \"waist\": 80, \"shoulder\": 45}",
  "deadline": "2025-12-31T00:00:00Z"
}

### Advance order status
PUT {{CouturierVision_API_HostAddress}}/api/orders/00000000-0000-0000-0000-000000000000/advance

### Register deposit
POST {{CouturierVision_API_HostAddress}}/api/orders/00000000-0000-0000-0000-000000000000/deposit
Content-Type: application/json

{
  "amount": 150.00
}
